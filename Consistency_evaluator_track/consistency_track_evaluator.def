Bootstrap: docker
From: python:3.13-slim

%files
    ./config.py /Consistency_evaluator_track/config.py
    ./data_loader.py /Consistency_evaluator_track/data_loader.py
    ./evaluator_content_handler.py /Consistency_evaluator_track/evaluator_content_handler.py 
    ./evaluator_metrics_calculator.py /Consistency_evaluator_track/evaluator_metrics_calculator.py
    ./consistency_evaluator_RestAPI.py /Consistency_evaluator_track/consistency_evaluator_RestAPI.py

%environment
    export APPTAINER_NO_MOUNT="home,tmp,proc,sys,dev"
    export LC_ALL=C
    export PYTHONPATH="/Consistency_evaluator_track:$PYTHONPATH"
    
%post
    # Install system packages and dependencies
    echo "Installing system dependencies..."
    apt-get update && \
    apt-get install -y --no-install-recommends python3-pip bzip2 ca-certificates && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

    echo "Installing Python dependencies..."
    python -m pip install --upgrade pip
    python -m pip install --no-cache-dir numpy tqdm pandas msgpack scipy requests
    
    # Set permissions to access all directories
    echo "Setting permissions for directories and script..."
    chmod -R 755 /Consistency_evaluator_track/

%runscript
    exec python3 /Consistency_evaluator_track/consistency_evaluator_RestAPI.py "$@"

%startscript
    exec python3 /Consistency_evaluator_track/consistency_evaluator_RestAPI.py "$@"

%labels
    Authors "Ishika Luthra, Satyam Priyadarshi"
    game_schema_version "1.0"
    Description "Consistency Evaluator (Track Requests for K562) for the GAME framework"

%help
    Consistency Evaluator (Track Requests for K562) for the GAME framework.
    Sends a structured track request to a Predictor, receives array predictions, and
    scores RC self-consistency using Pearson r on reversed arrays.

    Run:
        ```
        apptainer run \
          -B /abs/path/to/evaluator_data:/evaluator_data \
          -B /abs/path/to/predictions:/predictions \
          consistency_track_evaluator.sif PREDICTOR_HOST PREDICTOR_PORT /predictions
        ```

    Arguments:
        1. `PREDICTOR_HOST` : IP address or hostname of the Predictor server
        2. `PREDICTOR_PORT` : Port the Predictor is listening on
        3. `/predictions`   : Mounted path inside the container for per-gene predictions + summary CSV.

